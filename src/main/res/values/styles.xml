<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/robbyPurple</item>
        <item name="colorPrimaryDark">@color/robbyDarkPurple</item>
        <item name="colorAccent">@color/robbyDarkPurple</item>
    </style>

    <!-- Circle image style for profile pictures -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
    
    <!-- Rounded corners style for game covers and list covers -->
    <style name="RoundedCorners" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
</resources>