<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robbyWenge"
    tools:context=".GameReviewFragment">

    <LinearLayout
        android:id="@+id/review_input_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.496"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="290dp"
            android:src="@drawable/astrobot" />

        <EditText
            android:id="@+id/review_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Enter Review Title"
            android:inputType="text" />

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:isIndicator="false"
            android:numStars="5"
            android:progressTint="#FFEB3B"
            android:rating="1"
            android:stepSize="0.5"
            android:theme="@style/Base.Widget.AppCompat.RatingBar" />


        <EditText
            android:id="@+id/review_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/robbyKhaki"
            android:gravity="top"
            android:hint="Enter Review"
            android:inputType="textMultiLine"
            android:minLines="5" />

        <Button
            android:id="@+id/submit_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/robbyPurple"
            android:text="+Submit Review" />

        <Button
            android:id="@+id/delete_review"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/robbyPurple"
            android:text="-Delete Review"
            android:visibility="gone" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>