<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/robbyPurple"
    tools:context=".GameReviewFragment">

    <LinearLayout
        android:id="@+id/review_input_layout"
        android:layout_width="386dp"
        android:layout_height="726dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Space
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="40dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="624dp"
            android:background="@color/robbyWenge"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageView"
                android:layout_width="match_parent"
                android:layout_height="290dp"
                android:background="@color/robbyKhaki"
                android:src="@drawable/astrobot" />

            <LinearLayout
                android:id="@+id/title_input_layout"
                android:layout_width="353dp"
                android:layout_height="79dp"
                android:orientation="horizontal"
                android:padding="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/review_title"
                    android:layout_width="319dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="Here's the review_title"
                    android:textColor="@color/robbyDogwood"
                    android:textSize="20sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="15dp"
                android:src="@drawable/ic_line" />

            <FrameLayout
                android:layout_width="353dp"
                android:layout_height="113dp"
                android:layout_gravity="center"
                android:foregroundGravity="center"
                android:padding="1dp">

                <LinearLayout
                    android:layout_width="330dp"
                    android:layout_height="98dp"
                    android:layout_gravity="center"
                    android:foregroundGravity="center_horizontal"
                    android:gravity="center"
                    android:orientation="horizontal">


                    <RatingBar
                        android:id="@+id/ratingBar"
                        style="@android:style/Widget.Holo.RatingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:progressTint="#FFEB3B"
                        android:rating="0.0" />

                    <FrameLayout
                        android:layout_width="88dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center|top">

                        <co.ankurg.expressview.ExpressView
                            android:id="@+id/like_button"
                            android:layout_width="match_parent"
                            android:layout_height="94dp"
                            android:layout_gravity="center|top"
                            app:uncheckedIcon="@drawable/ic_like">

                        </co.ankurg.expressview.ExpressView>

                        <TextView
                            android:id="@+id/like_number"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:gravity="center"
                            android:text="0 likes"
                            android:textColor="@color/robbyDogwood"
                            android:textSize="15sp" />
                    </FrameLayout>

                </LinearLayout>

            </FrameLayout>

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="10dp"
                android:src="@drawable/ic_line" />

            <TextView
                android:id="@+id/review_body"
                android:layout_width="351dp"
                android:layout_height="113dp"
                android:background="@color/robbyKhaki"
                android:gravity="top"
                android:minLines="5"
                android:padding="5dp"
                android:text="placeholder"
                android:textColor="@color/robbyPurple"
                android:textSize="15sp" />
        </LinearLayout>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>