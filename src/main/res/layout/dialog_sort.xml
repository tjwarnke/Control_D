<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sort_by_date"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/date_sort_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/sort_newest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_newest"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/sort_oldest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_oldest"/>

    </com.google.android.material.chip.ChipGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/sort_by_name"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/name_sort_chips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:singleSelection="true"
        android:layout_marginBottom="16dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/sort_name_asc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_name_asc"/>

        <com.google.android.material.chip.Chip
            android:id="@+id/sort_name_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sort_name_desc"/>

    </com.google.android.material.chip.ChipGroup>

</LinearLayout>